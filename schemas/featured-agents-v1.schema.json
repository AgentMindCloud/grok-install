{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentmindcloud.github.io/grok-install/schemas/featured-agents-v1.schema.json",
  "title": "grok-install featured agents",
  "description": "The curated list of Grok-Native Certified agents surfaced on the grok-install gallery.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "updated_at", "agents"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^1\\.\\d+$",
      "description": "Schema major.minor — increment minor for additive fields, major for breaking changes."
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "stats": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "total_installs":   { "type": "integer", "minimum": 0 },
        "total_agents":     { "type": "integer", "minimum": 0 },
        "certified_count":  { "type": "integer", "minimum": 0 }
      }
    },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/agent" }
    }
  },
  "$defs": {
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id", "name", "description", "category", "tags",
        "install_command", "safety_profile", "certified", "installs", "author"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{1,62}[a-z0-9]$",
          "description": "Stable kebab-case identifier — used to cross-reference trending.json."
        },
        "name":        { "type": "string", "minLength": 2, "maxLength": 80 },
        "description": { "type": "string", "minLength": 10, "maxLength": 280 },
        "category": {
          "type": "string",
          "enum": ["x-native", "research", "voice", "discord", "telegram", "multi-agent", "community"]
        },
        "tags": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "uniqueItems": true,
          "minItems": 1,
          "maxItems": 10
        },
        "install_command": {
          "type": "string",
          "pattern": "^grok-install install [a-zA-Z0-9._-]+/[a-zA-Z0-9._-]+$"
        },
        "safety_profile": {
          "type": "string",
          "enum": ["strict", "moderate", "custom"]
        },
        "certified": { "type": "boolean" },
        "installs":  { "type": "integer", "minimum": 0 },
        "author":    { "type": "string", "pattern": "^@?[a-zA-Z0-9._-]+$" },
        "created_at":{ "type": "string", "format": "date-time" },
        "repo":      { "type": "string", "pattern": "^[a-zA-Z0-9._-]+/[a-zA-Z0-9._-]+$" }
      }
    }
  }
}
