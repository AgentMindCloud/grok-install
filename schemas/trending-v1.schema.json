{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentmindcloud.github.io/grok-install/schemas/trending-v1.schema.json",
  "title": "grok-install trending agents",
  "description": "Time-windowed install rankings for agents in featured-agents.json. Refreshed daily.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "updated_at", "window", "trending"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^1\\.\\d+$"
    },
    "updated_at": { "type": "string", "format": "date-time" },
    "window": {
      "type": "string",
      "enum": ["24h", "7d", "30d"],
      "description": "Trailing window for installs_window."
    },
    "trending": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "items": { "$ref": "#/$defs/entry" }
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "category", "installs_window", "installs_total", "rank"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{1,62}[a-z0-9]$",
          "description": "Must reference an id in featured-agents.json."
        },
        "name":             { "type": "string", "minLength": 2, "maxLength": 80 },
        "category": {
          "type": "string",
          "enum": ["x-native", "research", "voice", "discord", "telegram", "multi-agent", "community"]
        },
        "installs_window":  { "type": "integer", "minimum": 0 },
        "installs_total":   { "type": "integer", "minimum": 0 },
        "delta_pct":        { "type": "number" },
        "rank":             { "type": "integer", "minimum": 1 },
        "rank_prev":        { "type": ["integer", "null"], "minimum": 1 }
      }
    }
  }
}
