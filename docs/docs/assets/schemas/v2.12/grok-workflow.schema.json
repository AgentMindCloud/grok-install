{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentmindcloud.github.io/grok-docs/assets/schemas/v2.12/grok-workflow.schema.json",
  "title": "grok-workflow.yaml",
  "description": "Multi-step / multi-agent orchestration.",
  "type": "object",
  "required": ["workflow"],
  "additionalProperties": false,
  "properties": {
    "workflow": {
      "type": "object",
      "required": ["id", "steps"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "input_schema": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "enum": ["string", "number", "boolean", "object", "array"]
          }
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "agent"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
              "agent": { "type": "string" },
              "input": { "type": "object", "additionalProperties": true },
              "output": { "type": "string" },
              "when": {
                "type": "string",
                "description": "Jinja-style conditional, e.g. \"{{ x | length > 0 }}\""
              }
            }
          }
        }
      }
    }
  }
}
