{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "grok-install v2.4",
  "type": "object",
  "required": ["version", "name", "description"],
  "properties": {
    "version": { "type": "string", "enum": ["2.4"] },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "repository": { "type": "string", "format": "uri" },
    "category": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "featured": { "type": "boolean" },
    "ecosystem": { "type": "array", "items": { "type": "string" } },

    "llm": {
      "type": "object",
      "properties": {
        "provider": { "type": "string", "enum": ["xai", "openai", "anthropic", "ollama", "custom"] },
        "model": { "type": "string" },
        "api_key_env": { "type": "string" }
      }
    },

    "promotion": {
      "type": "object",
      "properties": {
        "auto_welcome": { "type": "boolean" },
        "share_installs": { "type": "boolean" },
        "weekly_highlight": { "type": "boolean" }
      }
    },

    "mode": { "type": "string", "enum": ["simple", "advanced"] },
    "preferred_deploy": { "type": "array", "items": { "type": "string" } },

    "deploy": {
      "type": "object",
      "properties": {
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "description": "Description shown to the user during private guided install"
          }
        }
      }
    },

    "security": {
      "type": "object",
      "properties": {
        "verified_by_grok": { "type": "boolean" },
        "safety_checklist": { "type": "boolean" }
      }
    },

    "update_strategy": { "type": "string", "enum": ["semver", "always"] },
    "auto_generate": { "type": "boolean" },

    "shareable_card": { "type": "boolean" },

    "on_install": {
      "type": "object",
      "properties": {
        "welcome_message": { "type": "string" }
      }
    },

    "community": {
      "type": "object",
      "properties": {
        "onboard": { "type": "boolean" },
        "voting_enabled": { "type": "boolean" },
        "moderation_level": { "type": "string" }
      }
    },

    "orchestration": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "role": { "type": "string" },
        "can_trigger": { "type": "array", "items": { "type": "string" } },
        "can_be_triggered_by": { "type": "array", "items": { "type": "string" } },
        "triggers": { "type": "array", "items": { "type": "object" } },
        "safety": { "type": "object" }
      }
    },

    "credits": {
      "type": "object",
      "properties": {
        "standard": { "type": "string" },
        "author": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "version": { "type": "string" },
        "message": { "type": "string" }
      }
    }
  }
}
