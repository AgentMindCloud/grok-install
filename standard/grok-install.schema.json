{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "grok-install",
  "description": "Official schema for grok-install v2.1",
  "type": "object",
  "required": ["version", "name", "description", "repository", "deploy"],
  "properties": {
    "version": {
      "type": "string",
      "enum": ["2.1"],
      "description": "Must be exactly 2.1"
    },
    "name": {
      "type": "string",
      "description": "Name of the agent"
    },
    "description": {
      "type": "string",
      "description": "Short clear description"
    },
    "repository": {
      "type": "string",
      "format": "uri",
      "description": "Full GitHub repository URL"
    },
    "category": {
      "type": "string",
      "description": "Category for marketplace discoverability (telegram, twitter, discord, etc.)"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Tags for better discoverability"
    },
    "ecosystem": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Musk ecosystem support (grok, x, tesla, starlink, xai, optimus)"
    },
    "deploy": {
      "type": "object",
      "required": ["target"],
      "properties": {
        "target": {
          "type": "string",
          "enum": ["railway", "vercel", "fly", "render", "local"]
        },
        "preferred_deploy": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Fallback order of deployment targets"
        }
      }
    },
    "prompts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key", "message"],
        "properties": {
          "key": { "type": "string" },
          "message": { "type": "string" }
        }
      },
      "description": "Private prompts for secrets"
    },
    "safety_checklist": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Optional safety rules"
    },
    "on_install": {
      "type": "object",
      "properties": {
        "welcome": { "type": "string" },
        "suggested_commands": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "update_strategy": {
      "type": "string",
      "enum": ["semver", "always"]
    }
  },
  "additionalProperties": false
}
