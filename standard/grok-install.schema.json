{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "grok-install",
  "description": "Official schema for grok-install v2.2 – Passive Growth + Safety + Marketplace",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "enum": ["2.2"]
    },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "repository": { "type": "string", "format": "uri" },
    "category": {
      "type": "string",
      "enum": ["telegram", "discord", "twitter", "web", "general"]
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "featured": { "type": "boolean" },
    "ecosystem": {
      "type": "array",
      "items": { "type": "string", "enum": ["grok", "x", "tesla", "starlink", "xai", "optimus"] }
    },
    "promotion": {
      "type": "object",
      "properties": {
        "auto_welcome": { "type": "boolean" },
        "share_installs": { "type": "boolean" },
        "weekly_highlight": { "type": "boolean" }
      },
      "default": {
        "auto_welcome": true,
        "share_installs": true,
        "weekly_highlight": true
      }
    },
    "preferred_deploy": {
      "type": "array",
      "items": { "type": "string", "enum": ["railway", "render", "fly", "local"] }
    },
    "mode": {
      "type": "string",
      "enum": ["simple", "advanced"],
      "default": "simple"
    },
    "deploy": {
      "type": "object",
      "properties": {
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "security": {
      "type": "object",
      "properties": {
        "verified_by_grok": { "type": "boolean" },
        "safety_checklist": { "type": "boolean" }
      },
      "default": {
        "verified_by_grok": true,
        "safety_checklist": true
      }
    },
    "update_strategy": {
      "type": "string",
      "enum": ["semver", "always"],
      "default": "semver"
    },
    "auto_generate": { "type": "boolean", "default": true },
    "shareable_card": { "type": "boolean", "default": true },
    "on_install": {
      "type": "object",
      "properties": {
        "welcome_message": { "type": "string" }
      }
    }
  },
  "required": ["version", "name", "description", "repository"],
  "additionalProperties": false
}
