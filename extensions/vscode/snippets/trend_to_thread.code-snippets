{
  "Grok: trend_to_thread pipeline": {
    "scope": "yaml",
    "prefix": "grok:trend",
    "description": "Expands a trend_pipeline + post_thread pairing for grok-agent.yaml.",
    "body": [
      "trend_pipeline:",
      "  source: \"${1|x-trending,x-follows,custom|}\"",
      "  window_minutes: ${2:15}",
      "  max_posts_per_hour: ${3:4}",
      "thread_posting:",
      "  max_posts: ${4:5}",
      "  cadence_seconds: ${5:60}",
      "capabilities:",
      "  - trend_to_thread",
      "  - post_thread",
      "$0"
    ]
  }
}
