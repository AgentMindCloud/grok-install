{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "\"", "close": "\"" },
    { "open": "'", "close": "'" }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*.*(:|-)\\s*$",
    "decreaseIndentPattern": "^\\s+$"
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*(?:-|[^:]+:)\\s*$",
      "action": { "indent": "indent" }
    }
  ]
}
