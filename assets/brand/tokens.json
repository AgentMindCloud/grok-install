    "atmosphere": "radial-gradient(ellipse 50% 50% at 80% 20%, rgba(255,122,61,0.08), transparent 60%), radial-gradient(ellipse 60% 60% at 20% 80%, rgba(199,62,29,0.05), transparent 70%), #0D0D0D"
  },
  "font": {
    "display": "Geist, system-ui, -apple-system, 'Segoe UI', sans-serif",
