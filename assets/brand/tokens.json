{
  "version": "1.0.0",
  "name": "Cinnabar Glass",
  "color": {
    "void": "#0D0D0D",
    "onyx": "#111113",
    "glassBase": "#1C1C1E",
    "cinnabar": "#C73E1D",
    "cinnabarGlow": "#E03C31",
    "amberGlow": "#FF7A3D",
    "mist": "#F5F5F5",
    "mist90": "rgba(245,245,245,0.90)",
    "mist70": "rgba(245,245,245,0.70)",
    "mist50": "rgba(245,245,245,0.50)",
    "mist30": "rgba(245,245,245,0.30)",
    "borderSoft": "rgba(255,255,255,0.08)",
    "borderStrong": "rgba(255,255,255,0.16)",
    "borderCinnabar": "rgba(199,62,29,0.55)"
  },
  "gradient": {
    "hero": "linear-gradient(180deg, #FF7A3D 0%, #C73E1D 100%)",
