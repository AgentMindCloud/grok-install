{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "color": {
    "bg":         { "$value": "#0a0706", "$type": "color", "$description": "Warm dark plate background." },
    "bone":       { "$value": "#ead5bd", "$type": "color", "$description": "Primary readable warm-bone on dark." },
    "bone-dim":   { "$value": "#baa590", "$type": "color", "$description": "Secondary text, muted labels." },
    "bone-faint": { "$value": "#7c6c5f", "$type": "color", "$description": "Hairline rules, dividers, faint UI." },
    "grid":       { "$value": "#f5e8d8", "$type": "color", "$description": "Plate grid wash (used at low alpha)." },
    "accent":     { "$value": "#d44936", "$type": "color", "$description": "Cinnabar red — sole accent. Use sparingly." }
  },
  "font": {
    "serif": { "$value": "'Instrument Serif', 'Playfair Display', 'EB Garamond', Georgia, serif", "$type": "fontFamily" },
    "mono":  { "$value": "'IBM Plex Mono', 'JetBrains Mono', Menlo, Monaco, 'Courier New', monospace", "$type": "fontFamily" }
  }
}
